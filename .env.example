# ─── Novan — Development Environment ──────────────────────────────────────────
# Copy to .env (gitignored). Local-dev values; safe defaults.

# Runtime mode — set to 'cloud-api-only' to block local sandbox execution
RUNTIME_MODE=local

# Database — local Postgres via docker compose
DATABASE_URL=postgres://novan:novan@localhost:5432/novan

# Redis — local Redis via docker compose
REDIS_URL=redis://localhost:6379

# Frontend → backend
VITE_API_BASE_URL=http://localhost:3001
API_PORT=3001
API_HOST=0.0.0.0

# Auth (dev — replace in prod)
AUTH_SECRET=dev-only-not-secure-replace-in-production

# Vault master key (dev fallback — production MUST set this to 32 bytes base64)
VAULT_MASTER_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI Providers (optional in dev) ───────────────────────────────────────────
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Runtime safety flags (env-level defaults; DB overrides at runtime) ───────
PROVIDER_ROUTER_ENABLED=true
BUDGET_GUARDS_ENABLED=true
KILL_SWITCH_ENABLED=true

# ─── Telemetry (optional) ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# ─── Cron control ─────────────────────────────────────────────────────────────
# Set to 1 to disable all background scans (incident, improvement, security)
DISABLE_LEARNING_CRON=
