# ─── Novan — Production Environment ───────────────────────────────────────────
# Copy to .env.production and fill in real values. NEVER commit the real file.

# ─── CORE RUNTIME ─────────────────────────────────────────────────────────────

# Runtime mode — 'cloud-api-only' refuses any local sandbox execution.
# Use this on Render/Railway/Fly where local FS write to repo is not appropriate.
RUNTIME_MODE=cloud-api-only

NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info

# ─── DATABASE (Neon) ──────────────────────────────────────────────────────────
# Copy from Neon dashboard → "Connection string" (use the pooler URL for serverless)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/novan?sslmode=require

# ─── REDIS (Upstash) ──────────────────────────────────────────────────────────
# Copy from Upstash → Redis → "Connect" → ioredis-compatible URL
REDIS_URL=rediss://default:PASSWORD@elegant-thing.upstash.io:6379

# ─── FRONTEND → BACKEND ───────────────────────────────────────────────────────
# Public URL of the deployed Render/Railway API
VITE_API_BASE_URL=https://novan-api.onrender.com

# CORS — public URLs of your Vercel deploy(s)
CORS_ORIGINS=https://novan.vercel.app,https://app.novan.com

# ─── SECURITY ─────────────────────────────────────────────────────────────────

# Auth — generate with: openssl rand -base64 48
AUTH_SECRET=

# Secrets vault master key — EXACTLY 32 bytes base64
# Generate with: openssl rand -base64 32
VAULT_MASTER_KEY=

# ─── AI PROVIDERS ─────────────────────────────────────────────────────────────
# At least one required if you want AI calls to succeed.

OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── PROVIDER ROUTER + GOVERNANCE ─────────────────────────────────────────────
# Tonight defaults — all guards ON.
PROVIDER_ROUTER_ENABLED=true
BUDGET_GUARDS_ENABLED=true
KILL_SWITCH_ENABLED=true

# ─── BILLING (optional) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ─── TELEMETRY (optional) ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── CRON CONTROL ─────────────────────────────────────────────────────────────
# Disable background scans by setting DISABLE_LEARNING_CRON=1
DISABLE_LEARNING_CRON=

# ─── NOTES ────────────────────────────────────────────────────────────────────
# Tonight Mode flags live in the database (runtime_safety_flags table).
# All dangerous autonomy is OFF by default. Toggle via /launch-tonight UI.
