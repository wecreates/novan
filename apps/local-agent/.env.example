# R357 Local Agent env — copy to .env.local (gitignored) and fill.
# NEVER commit a populated .env.local.

NOVAN_API_BASE=https://137-184-198-2.sslip.io
NOVAN_OPS_TOKEN=
NOVAN_WORKSPACE_ID=default

# Where the persistent Chromium profile lives (cookies, localStorage).
# Keep this OUT of git — it contains your platform sessions.
NOVAN_PROFILE_PATH=./.profile

# Where decoded design files cache to (relative to apps/local-agent).
NOVAN_DESIGNS_ROOT=../../designs

# Loop interval (seconds) between full platform sweeps.
NOVAN_POLL_SECONDS=180

# Headed mode for first-time logins. Once cookies persist, you CAN set =true.
NOVAN_HEADLESS=false

# Comma-separated platforms to enable. Empty = all.
NOVAN_PLATFORMS=

# Dry-run: fill everything but skip the final Publish click.
NOVAN_DRY_RUN=false
