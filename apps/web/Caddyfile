:8080 {
  root * /srv
  encode gzip zstd

  # R146 — order matters: `handle /api/*` (and the other API path prefixes)
  # must be evaluated BEFORE the SPA `try_files`/`file_server` fallback,
  # otherwise try_files rewrites /api/v1/* to /index.html and the proxy
  # block never matches. The previous layout (file_server + try_files at
  # the top of the block) sent /api/v1/chat/stream to the SPA, breaking
  # the PWA chat in production. Each upstream route lives inside its own
  # `handle` so the default SPA fallback only runs when nothing matched.
  handle /api/* {
    reverse_proxy {$API_UPSTREAM:api:3001}
  }
  handle /docs* {
    reverse_proxy {$API_UPSTREAM:api:3001}
  }
  handle /metrics* {
    reverse_proxy {$API_UPSTREAM:api:3001}
  }
  handle /health* {
    reverse_proxy {$API_UPSTREAM:api:3001}
  }

  # Default handle = SPA. Try the asset on disk, fall back to index.html
  # so client-side routing works for any unknown path.
  handle {
    try_files {path} /index.html
    file_server
  }

  # Long-cache static assets
  @assets path /assets/*
  header @assets Cache-Control "public, max-age=31536000, immutable"

  # No-cache the entry HTML
  @html path / /index.html
  header @html Cache-Control "no-cache, no-store, must-revalidate"

  # Security headers
  header {
    Strict-Transport-Security "max-age=63072000; includeSubDomains"
    X-Content-Type-Options    "nosniff"
    X-Frame-Options           "DENY"
    Referrer-Policy           "strict-origin-when-cross-origin"
    Permissions-Policy        "geolocation=(), camera=(), microphone=()"
    -Server
  }
}
