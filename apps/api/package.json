{
  "name": "@ops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "node --env-file=../../.env --import tsx/esm src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.1.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@fastify/websocket": "^11.0.1",
    "@neondatabase/serverless": "^0.10.0",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.54.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.54.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-metrics": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@ops/ai-router": "workspace:*",
    "@ops/db": "workspace:*",
    "@ops/event-contracts": "workspace:*",
    "@ops/policy-engine": "workspace:*",
    "@ops/provider-router": "workspace:*",
    "@ops/runtime-kernel": "workspace:*",
    "@ops/service-recovery": "workspace:*",
    "@ops/shared-types": "workspace:*",
    "@ops/workflow-engine": "workspace:*",
    "bullmq": "^5.24.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "playwright": "^1.44.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/uuid": "*",
    "@types/ws": "^8.5.13",
    "@vitest/ui": "^2.1.9",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "*",
    "vitest": "^2.1.9"
  }
}
